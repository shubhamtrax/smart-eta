<div
    id="smarteta-widget"
    class="smarteta-widget"
    style="--smarteta-accent: {{ block.settings.accent_color }}; --smarteta-radius: {{ block.settings.corner_radius }}px;"
    data-product-handle="{{ product.handle }}"
    data-vendor="{{ product.vendor | escape }}"
    data-tags="{{ product.tags | join: ',' }}"
    data-collections="{% for c in product.collections %}{{ c.handle }}{% unless forloop.last %},{% endunless %}{% endfor %}"
>

    <div id="smarteta-countdown" class="smarteta-countdown" style="display:none;"></div>

    <div class="smarteta-header">

        <div class="smarteta-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 21s-7-6.1-7-11.4C5 6 8.1 3 12 3s7 3 7 6.6C19 14.9 12 21 12 21Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                <circle cx="12" cy="9.5" r="2.4" stroke="currentColor" stroke-width="1.7"/>
            </svg>
        </div>

        <div>

            <h3>{{ block.settings.heading }}</h3>

            <p>{{ block.settings.description }}</p>

        </div>

    </div>

    <div class="smarteta-search">

        <input
            id="smarteta-pincode"
            type="text"
            inputmode="numeric"
            placeholder="Enter 6-digit pincode"
            maxlength="6"
        >

        <button id="smarteta-check" type="button">
            Check
        </button>

    </div>

    <div id="smarteta-result" class="smarteta-result"></div>

</div>


{% schema %}
{
  "name": "SmartETA Delivery Checker",
  "target": "section",
  "stylesheet": "smarteta.css",
  "javascript": "smarteta.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check Delivery Availability"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Enter your pincode to see delivery estimate."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    }
  ]
}
{% endschema %}
